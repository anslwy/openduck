{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDuck",
  "identifier": "com.openduck.app",
  "version": "1.0.0",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenDuck",
        "width": 600,
        "height": 600,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
      "active": true,
      "targets": "all",
      "resources": [
        "resources/**/*",
        "../sample-male.mp3",
        "../sample-female.mp3"
      ],
      "externalBin": [
        "bin/mlx-handler"
      ],
      "macOS": {
        "infoPlist": "Info.plist"
      },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
