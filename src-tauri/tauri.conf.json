{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDuck",
  "identifier": "com.openduck.app",
  "version": "1.0.0",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 700,
        "height": 770,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*.py",
      "resources/silero_vad.onnx",
      "../scripts/setup_python_env.sh",
      "../sample-male.mp3",
      "../sample-male-transcript.txt",
      "../sample-female.mp3",
      "../sample-female-transcript.txt",
      "../characters/*.openduck"
    ],
    "fileAssociations": [
      {
        "ext": ["openduck"],
        "name": "OpenDuck Contact",
        "description": "OpenDuck contact profile",
        "role": "Editor",
        "rank": "Owner",
        "mimeType": "application/json",
        "exportedType": {
          "identifier": "com.openduck.contact",
          "conformsTo": ["public.json"]
        }
      }
    ],
    "externalBin": ["bin/mlx-handler"],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/macos/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGNUEyMTMxNkU0QjNCQTkKUldTcE8wdHVNU0ZhWDRxWjI2TFpSMWZYNzBsWGQ3eDNldGJUUUZYeEQyMFlHSGIxMS9OYnEzbmMK",
      "endpoints": [
        "https://github.com/anslwy/openduck/releases/latest/download/latest.json"
      ]
    }
  }
}
